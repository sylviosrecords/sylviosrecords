# ============================================
# Sylvios Records Backend - Configurações
# ============================================

# Seu Seller ID do Mercado Livre
# Para encontrar: acesse seu perfil no ML e veja a URL
# Ex: https://www.mercadolivre.com.br/perfil/SYLVIOSRECORDS
# Ou vá em: https://api.mercadolibre.com/sites/MLB/search?nickname=SYLVIOSRECORDS
# e pegue o campo "seller.id"
ML_SELLER_ID=SEU_ID_AQUI

# Porta do servidor (padrão: 3001)
PORT=3001

# URL do frontend (para CORS) - em produção coloque o domínio exato
# Ex: https://sylviosrecords.com.br
FRONTEND_URL=*
